# Copy this file to .env and fill in your credentials.

# Public (exposed to browser) — required.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side only (Vercel env vars, never prefixed with VITE_).
# SUPABASE_SERVICE_ROLE_KEY is required for the admin API routes.
# ODDS_API_KEY is optional — enables odds-based tiering for the four majors via
# https://the-odds-api.com (free tier = 500 requests/month, way more than needed).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ODDS_API_KEY=your-odds-api-key
